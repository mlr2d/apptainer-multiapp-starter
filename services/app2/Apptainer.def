Bootstrap: docker
From: python:3.11-slim

%post
    python -m pip install --no-cache-dir --upgrade pip
    python -m pip install --no-cache-dir -r /opt/app/requirements.txt

%files
    app /opt/app/app
    wsgi.py /opt/app/wsgi.py
    requirements.txt /opt/app/requirements.txt

%environment
    export PYTHONUNBUFFERED=1

%startscript
    cd /opt/app
    PORT="${1:-${PORT:-8080}}"
    exec gunicorn --bind "0.0.0.0:${PORT}" --workers "${GUNICORN_WORKERS:-1}" --threads "${GUNICORN_THREADS:-2}" wsgi:app
